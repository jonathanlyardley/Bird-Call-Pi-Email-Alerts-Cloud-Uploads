# Copy this file outside the repository before editing.
# Suggested path:
# /opt/bird-call-alerts/secrets/email.env

SMTP_USER=your-alert-account@example.com
SMTP_PASS=replace-with-your-smtp-app-password
TO_ADDRESSES=you@example.com

# Comma-separated common or scientific names. Matching is case-insensitive.
PRIORITY_SPECIES=Tawny Owl,Barn Owl,Red Kite,Common Swift

# Optional public-safe label used in e-mail subjects and bodies.
STATION_LABEL=Bird monitoring station
